&GLOBAL
 PROJECT_NAME Si
 RUN_TYPE ENERGY
&END GLOBAL
&FORCE_EVAL
 METHOD Quickstep
 &DFT
  BASIS_SET_FILE_NAME BASIS_MOLOPT
  POTENTIAL_FILE_NAME GTH_POTENTIALS
  &MGRID
   CUTOFF 400
   REL_CUTOFF 60
  &END MGRID
  &SCF
   EPS_SCF 1.0E-6
  &END SCF
 &END DFT
 &SUBSYS
  &CELL
   ABC 5.43 5.43 5.43
   PERIODIC XYZ
  &END CELL
  &COORD
   Si 0 0 0
   Si 1.3575 1.3575 1.3575
  &END COORD
  &KIND Si
   BASIS_SET DZVP-MOLOPT-SR-GTH
   POTENTIAL GTH-PBE
  &END KIND
 &END SUBSYS
&END FORCE_EVAL
